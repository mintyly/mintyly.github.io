---
import { getCollection } from 'astro:content';
import '../styles/kangel.css';
const posts = await getCollection('ctfblog');
const writeups = await getCollection('writeups');

const writeupsByCompetition = new Map<string, typeof writeups>();
for (const writeup of writeups) {
  const group = writeupsByCompetition.get(writeup.data.competition) ?? [];
  group.push(writeup);
  writeupsByCompetition.set(writeup.data.competition, group);
}
---

<div id="container">
  <div id="container2">
    <div class="window hoverable-window">
      <div class="title-bar">
        <div class="btn box"></div>
        <div class="title">ctf blog.txt</div>
        <div class="window-controls">
          <div class="btn close"></div>
          <div class="btn minimize"></div>
          <div class="btn maximize"></div>
        </div>
      </div>

      <div class="content">
        <section>
          <ul>
            {posts.map(post => (
              <li>
                <a href={`/ctfblog/${post.slug}/`}>{post.data.title}</a>
                <span> — {post.data.date}</span>
              </li>
            ))}
          </ul>
        </section>

        <section id="writeups">
          <h2>Writeups</h2>
          {[...writeupsByCompetition.entries()].map(([competition, entries]) => (
            <div class="writeup-group">
              <h3>{competition}</h3>
              <ul>
                {entries.map(writeup => (
                  <li>
                    <a href={`/ctfblog/writeups/${writeup.id}/`}>{writeup.data.challenge}</a>
                    {writeup.data.category && <span class="tag">{writeup.data.category}</span>}
                    {writeup.data.difficulty && <span class="tag">{writeup.data.difficulty}</span>}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </section>
      </div>

      <div class="bottom-bar">
        <div class="btmbtn main"></div>
        <div class="btmbtn small"></div>
        <div class="btmbtn small"></div>
        <div class="btmbtn small"></div>
      </div>
    </div>
  </div>
</div>